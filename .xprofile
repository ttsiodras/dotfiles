# Sourced by GDM (via /etc/X11/Xsession.d/40x11-common_xsessionrc) after
# ~/.Xresources is merged, and by ~/.xinitrc on startx machines. This is the
# one place both paths agree on, so merge ALL X resources here to guarantee
# identical results under GDM and startx. GDM merges ~/.Xresources on its own;
# re-merging is harmless (idempotent). ~/.Xdefaults is NOT merged by GDM, so it
# would be lost without this. ~/.Xresources.local (per-machine, not in the
# dotfiles repo) is merged last so it wins.
xrdb -merge "$HOME/.Xresources"
[ -f "$HOME/.Xdefaults" ]        && xrdb -merge "$HOME/.Xdefaults"
[ -f "$HOME/.Xresources.local" ] && xrdb -merge "$HOME/.Xresources.local"
