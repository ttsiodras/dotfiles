*VT100*foreground:      grey66
*VT100*colorBDMode:     true
*VT100*background:      black
*VT100*saveLines:       2500
*VT100*scrollBar:       true
*VT100*visualBell:      true
*XTerm*font:            Droid Sans Mono
*XTerm*faceName:        Droid Sans Mono
*XTerm*faceSize:        7
*XTerm*renderFont:      true

*XTerm*faceNameDoublesize: Droid Sans Mono
*XTerm*fontMenu*fontdefault*Label: Default
*XTerm*fontMenu*font1*Label: Unreadable
XTerm*font1: xft:Droid Sans Mono:size=4
*XTerm*fontMenu*font2*Label: Tiny
XTerm*font2: xft:Droid Sans Mono:size=5
*XTerm*fontMenu*font3*Label: Small
XTerm*font3: xft:Droid Sans Mono:size=6
*XTerm*fontMenu*font4*Label: Medium
XTerm*font4: xft:Droid Sans Mono:size=7
*XTerm*fontMenu*font5*Label: Large
XTerm*font5: xft:Droid Sans Mono:size=8
*XTerm*fontMenu*font6*Label: Huge
XTerm*font6: xft:Droid Sans Mono:size=9

! http://lukas.zapletalovi.com/2013/07/hidden-gems-of-xterm.html
! word selection selects urls and files/paths completely
XTerm*charClass: 33:48,36-47:48,58-59:48,61:48,63-64:48,95:48,126:48
XTerm*on3Clicks: regex ([[:alpha:]]+://)?([[:alnum:]!#+,./=?@_~-]|(%[[:xdigit:]][[:xdigit:]]))+

! All custom key bindings in one override block:
! - Meta-/ : dabbrev-expand from everything on screen
!   (http://unix.stackexchange.com/questions/119679)
! - Shift-arrows : selection paste / scrollback
! - Ctrl-9 / Ctrl-0 : smaller / larger font
XTerm*VT100.Translations: #override \n\
     Meta <Key>/: dabbrev-expand() \n\
     Shift <Key>Right: insert-selection(PRIMARY) \n\
     Shift <Key>Up: scroll-back(4) \n\
     Shift <Key>Down: scroll-forw(4) \n\
     Ctrl <Key> 9: smaller-vt-font() \n\
     Ctrl <Key> 0: larger-vt-font()

*XTerm*allowWindowOps: true
*XTerm*allowFontOps: true
*XTerm*allowTitleOps: true
